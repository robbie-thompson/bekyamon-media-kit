{
  "name": "bekyamon-media-kit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "npm run build && wrangler dev",
    "build": "rm -rf dist && vite build && cp cloudflare/_headers cloudflare/404.html dist/",
    "preview": "vite preview",
    "test": "node --test",
    "check": "npm run test && npm run build",
    "deploy": "npm run check && wrangler deploy"
  },
  "dependencies": {
    "lucide": "^0.468.0"
  },
  "devDependencies": {
    "vite": "^6.0.7",
    "wrangler": "^4.0.0"
  }
}
