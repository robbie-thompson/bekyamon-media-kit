{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bekyamon-media-kit",
  "main": "worker/index.js",
  "compatibility_date": "2026-07-13",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*", "/admindashboard", "/admindashboard/*", "/mediakit", "/mediakit/*"]
  },
  "kv_namespaces": [
    {
      "binding": "MEDIA_KIT_KV",
      "id": "18c05989af104981895794e94a6e891c"
    }
  ]
}
